{
  "name": "{{PROJECT_NAME}} PyTorch ML Development",
  "build": {
    "dockerfile": "Dockerfile"
  },

  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/common-utils:2": {
      "username": "{{DEV_USER}}",
      "uid": "{{DEV_UID}}",
      "gid": "{{DEV_UID}}",
      "upgradePackages": false
    },
    "ghcr.io/anthropics/devcontainer-features/claude-code:1": {}
  },

  "runArgs": [
    "--runtime=nvidia",
    "--ipc=host",
    "--memory=20g",
    "--cpus=8",
    "--ulimit=memlock=-1",
    "--ulimit=stack=67108864",
    "--cap-add=SYS_PTRACE",
    "--security-opt=seccomp=unconfined",
    "--mount", "type=bind,source=${env:SSH_AUTH_SOCK},target=/tmp/ssh-agent.sock",
    "--mount", "type=bind,source=${localEnv:HOME}/.config/gcloud,target=/home/{{DEV_USER}}/.config/gcloud,readonly",
    "--mount", "type=bind,source=${localEnv:HOME}/data,target=/data"
  ],

  "containerEnv": {
    "NVIDIA_VISIBLE_DEVICES": "all",
    "CUDA_VISIBLE_DEVICES": "0",
    "PYTORCH_CUDA_ALLOC_CONF": "expandable_segments:True,max_split_size_mb:512,garbage_collection_threshold:0.6",
    "PYTHONPATH": "/workspaces/{{PROJECT_NAME}}/src",
    "HF_HOME": "/workspaces/{{PROJECT_NAME}}/.cache/huggingface",
    "TORCH_HOME": "/workspaces/{{PROJECT_NAME}}/.cache/torch",
    "TRANSFORMERS_CACHE": "/workspaces/{{PROJECT_NAME}}/.cache/huggingface/transformers",
    "SSH_AUTH_SOCK": "/tmp/ssh-agent.sock",
    "UV_PROJECT_ENVIRONMENT": "/workspaces/{{PROJECT_NAME}}/.venv",
    "VIRTUAL_ENV": "/workspaces/{{PROJECT_NAME}}/.venv",
    "ANTHROPIC_VERTEX_PROJECT_ID": "${localEnv:ANTHROPIC_VERTEX_PROJECT_ID}",
    "ANTHROPIC_VERTEX_REGION": "${localEnv:ANTHROPIC_VERTEX_REGION}",
    "CLAUDE_CODE_USE_VERTEX": "${localEnv:CLAUDE_CODE_USE_VERTEX}"
  },


  "mounts": [
    "source={{PROJECT_NAME}}-models,target=/workspaces/{{PROJECT_NAME}}/models,type=volume",
    "source={{PROJECT_NAME}}-datasets,target=/workspaces/{{PROJECT_NAME}}/data,type=volume",
    "source={{PROJECT_NAME}}-cache-hf,target=/workspaces/{{PROJECT_NAME}}/.cache/huggingface,type=volume",
    "source={{PROJECT_NAME}}-cache-torch,target=/workspaces/{{PROJECT_NAME}}/.cache/torch,type=volume"
  ],



  "workspaceFolder": "/workspaces/{{PROJECT_NAME}}",
  "remoteUser": "{{DEV_USER}}",

  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/workspaces/{{PROJECT_NAME}}/.venv/bin/python",
        "python.terminal.activateEnvironment": true,
        "files.watcherExclude": {
          "**/.cache/**": true,
          "**/models/**": true,
          "**/data/**": true
        },
        "terminal.integrated.defaultProfile.linux": "bash",
        "editor.formatOnSave": true,
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff",
          "editor.codeActionsOnSave": {
            "source.fixAll": "explicit",
            "source.organizeImports": "explicit"
          }
        },
        "ruff.enable": true,
        "ruff.organizeImports": true
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "ms-toolsai.jupyter",
        "GitHub.copilot"
      ]
    },
    "jetbrains": {
      "backend": "IU",
      "plugins": [
        "PythonCore",
        "net.ashald.envfile",
        "ru.adelf.idea.dotenv",
        "net.seesharpsoft.intellij.plugins.csv",
        "nl.bryanderidder.regexrenamefiles",
        "com.intellij.plugins.watcher",
        "intellij.python.lsp"
      ]
    }
  },

  "forwardPorts": [6006, 8888],

  "postCreateCommand": ".devcontainer/setup-environment.sh",
  "postStartCommand": "cat /workspaces/{{PROJECT_NAME}}/GETTING_STARTED.md 2>/dev/null || true",
  "hostRequirements": {
    "gpu": true,
    "memory": "24gb"
  },

}
